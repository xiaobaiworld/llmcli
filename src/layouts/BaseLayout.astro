---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'CLI tools rated for AI agent use. Find agent-ready command-line tools with agent-ready scores.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Search Console 验证 -->
    <meta name="google-site-verification" content="dNPE4tu3bN9Jq55P1B69YoTtNFS-7z9-BNBpUtne1GY" />
    <!-- Google Analytics GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DLGJDH7H4N"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DLGJDH7H4N');
    </script>
  </head>
  <body class="bg-white text-gray-900 antialiased min-h-screen flex flex-col">
    <header class="border-b border-gray-200 sticky top-0 bg-white/95 backdrop-blur z-10">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 no-underline group">
          <span class="font-mono font-bold text-lg text-gray-900 group-hover:text-green-600 transition-colors">
            llmcli
          </span>
          <span class="text-gray-400 text-sm hidden sm:inline">CLI tools for AI agents</span>
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <a
            href="https://github.com/your-org/llmcli"
            class="text-gray-500 hover:text-gray-900 transition-colors"
            target="_blank"
            rel="noopener"
          >
            GitHub
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-16">
      <div class="max-w-6xl mx-auto px-4 py-8 text-center text-sm text-gray-400">
        <p>
          llmcli — CLI tools, rated for AI agent use.
        </p>
        <p class="mt-1">
          Data:
          <a href="/data/tools.seed.yaml" class="underline hover:text-gray-600">tools.seed.yaml</a>
          &middot;
          <a
            href="https://github.com/your-org/llmcli"
            class="underline hover:text-gray-600"
            target="_blank"
            rel="noopener"
          >
            Contribute on GitHub
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>
