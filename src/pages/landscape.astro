---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLandscape, getLandscapeStats, LANDSCAPE_CATEGORY_LABELS } from '../lib/landscape.ts';

const entries = getLandscape();
const stats = getLandscapeStats(entries);

// Group by category for the filter tabs
const categories = [...new Set(entries.map(e => e.category))].sort();
---

<BaseLayout
  title="软件 MCP/CLI 全景图 — llmcli"
  description={`${stats.total} 个主流软件的 MCP/CLI 支持状态：${stats.officialMcp} 个有官方 MCP，${stats.communityMcp} 个有社区 MCP，${stats.hasCli} 个有 CLI。`}
>
  <div data-pagefind-body>

    <!-- Breadcrumb -->
    <div class="border-b border-gray-200 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 py-3 text-sm text-gray-400">
        <a href="/" class="hover:text-gray-700 transition-colors">首页</a>
        <span class="mx-2">/</span>
        <span class="text-gray-700">全景图</span>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-8">

      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-2">软件 MCP/CLI 全景图</h1>
        <p class="text-gray-500 mb-5">
          {stats.total} 个主流软件的 Agent 接入状态——有没有 MCP、是官方还是社区、有没有 CLI。
        </p>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-4 text-sm">
          <div class="flex items-center gap-2 bg-green-50 border border-green-100 rounded-lg px-3 py-2">
            <span class="w-2 h-2 rounded-full bg-green-500 shrink-0"></span>
            <span class="font-semibold text-green-800">{stats.officialMcp}</span>
            <span class="text-green-700">官方 MCP</span>
          </div>
          <div class="flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-lg px-3 py-2">
            <span class="w-2 h-2 rounded-full bg-blue-400 shrink-0"></span>
            <span class="font-semibold text-blue-800">{stats.communityMcp}</span>
            <span class="text-blue-700">社区 MCP</span>
          </div>
          <div class="flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2">
            <span class="w-2 h-2 rounded-full bg-gray-300 shrink-0"></span>
            <span class="font-semibold text-gray-700">{stats.noMcp}</span>
            <span class="text-gray-500">暂无 MCP</span>
          </div>
          <div class="flex items-center gap-2 bg-violet-50 border border-violet-100 rounded-lg px-3 py-2">
            <span class="font-mono text-xs font-bold text-violet-700">CLI</span>
            <span class="font-semibold text-violet-800">{stats.hasCli}</span>
            <span class="text-violet-700">有 CLI</span>
          </div>
        </div>
      </div>

      <!-- Filter bar -->
      <div class="flex flex-wrap gap-2 mb-4" id="filter-bar">
        <button
          data-filter="all"
          class="filter-btn active px-3 py-1.5 rounded-lg text-sm font-medium border transition-colors bg-gray-900 text-white border-gray-900"
        >
          全部 ({stats.total})
        </button>
        <button
          data-filter="official"
          class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium border transition-colors bg-white text-gray-600 border-gray-200 hover:border-gray-400"
        >
          官方 MCP ({stats.officialMcp})
        </button>
        <button
          data-filter="community"
          class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium border transition-colors bg-white text-gray-600 border-gray-200 hover:border-gray-400"
        >
          社区 MCP ({stats.communityMcp})
        </button>
        <button
          data-filter="none"
          class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium border transition-colors bg-white text-gray-600 border-gray-200 hover:border-gray-400"
        >
          暂无 MCP ({stats.noMcp})
        </button>
        <button
          data-filter="cli"
          class="filter-btn px-3 py-1.5 rounded-lg text-sm font-medium border transition-colors bg-white text-gray-600 border-gray-200 hover:border-gray-400"
        >
          有 CLI ({stats.hasCli})
        </button>
      </div>

      <!-- Category filter -->
      <div class="flex flex-wrap gap-1.5 mb-6" id="category-bar">
        <button
          data-category="all"
          class="cat-btn active px-2.5 py-1 rounded-md text-xs font-medium border transition-colors bg-gray-700 text-white border-gray-700"
        >
          所有类别
        </button>
        {categories.map(cat => (
          <button
            data-category={cat}
            class="cat-btn px-2.5 py-1 rounded-md text-xs font-medium border transition-colors bg-white text-gray-500 border-gray-200 hover:border-gray-400"
          >
            {LANDSCAPE_CATEGORY_LABELS[cat] ?? cat}
          </button>
        ))}
      </div>

      <!-- Table -->
      <div class="border border-gray-200 rounded-xl overflow-hidden">
        <table class="w-full text-sm" id="landscape-table">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200 text-left">
              <th class="px-4 py-2.5 font-semibold text-gray-700">软件</th>
              <th class="px-4 py-2.5 font-semibold text-gray-700 hidden md:table-cell">公司</th>
              <th class="px-4 py-2.5 font-semibold text-gray-700 hidden sm:table-cell">类别</th>
              <th class="px-4 py-2.5 font-semibold text-gray-700 text-center">MCP</th>
              <th class="px-4 py-2.5 font-semibold text-gray-700 text-center">CLI</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100" id="landscape-tbody">
            {entries.map(entry => (
              <tr
                class="hover:bg-gray-50 transition-colors landscape-row"
                data-mcp-type={entry.mcp_type}
                data-has-cli={entry.has_cli ? 'true' : 'false'}
                data-category={entry.category}
              >
                <!-- Software name -->
                <td class="px-4 py-3">
                  <div class="font-medium text-gray-900">{entry.name}</div>
                  <a
                    href={entry.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs text-gray-400 hover:text-blue-600 transition-colors"
                  >
                    {entry.website.replace('https://', '')} ↗
                  </a>
                </td>

                <!-- Company -->
                <td class="px-4 py-3 hidden md:table-cell">
                  <span class="text-gray-500 text-xs">{entry.company}</span>
                </td>

                <!-- Category -->
                <td class="px-4 py-3 hidden sm:table-cell">
                  <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full">
                    {LANDSCAPE_CATEGORY_LABELS[entry.category] ?? entry.category}
                  </span>
                </td>

                <!-- MCP status -->
                <td class="px-4 py-3 text-center">
                  {entry.mcp_type === 'official' ? (
                    <a
                      href={entry.mcp_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 text-xs font-semibold text-green-700 bg-green-50 border border-green-200 px-2 py-0.5 rounded-full hover:bg-green-100 transition-colors"
                    >
                      ✓ 官方
                    </a>
                  ) : entry.mcp_type === 'community' ? (
                    <a
                      href={entry.mcp_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 text-xs font-semibold text-blue-700 bg-blue-50 border border-blue-200 px-2 py-0.5 rounded-full hover:bg-blue-100 transition-colors"
                    >
                      ⚡ 社区
                    </a>
                  ) : (
                    <span class="text-xs text-gray-300">—</span>
                  )}
                </td>

                <!-- CLI status -->
                <td class="px-4 py-3 text-center">
                  {entry.has_cli && entry.cli_url ? (
                    <a
                      href={entry.cli_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-block text-xs font-mono font-semibold text-violet-700 bg-violet-50 border border-violet-200 px-2 py-0.5 rounded hover:bg-violet-100 transition-colors"
                    >
                      {entry.cli_name ?? 'CLI'}
                    </a>
                  ) : entry.has_cli ? (
                    <span class="text-xs font-mono text-violet-600">{entry.cli_name ?? 'CLI'}</span>
                  ) : (
                    <span class="text-xs text-gray-300">—</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Empty state (hidden by default) -->
      <div id="empty-state" class="hidden text-center py-12 text-gray-400 text-sm">
        没有符合条件的软件
      </div>

      <p class="text-xs text-gray-400 mt-4">
        数据每周通过 GitHub Actions 自动更新 · 最后核查：{entries[0]?.last_checked ?? '—'}
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const rows = document.querySelectorAll<HTMLTableRowElement>('.landscape-row');
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const catBtns = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const emptyState = document.getElementById('empty-state')!;

  let activeFilter = 'all';
  let activeCategory = 'all';

  function applyFilters() {
    let visible = 0;
    rows.forEach(row => {
      const mcpType = row.dataset.mcpType!;
      const hasCli = row.dataset.hasCli === 'true';
      const category = row.dataset.category!;

      const matchFilter =
        activeFilter === 'all' ||
        (activeFilter === 'official' && mcpType === 'official') ||
        (activeFilter === 'community' && mcpType === 'community') ||
        (activeFilter === 'none' && mcpType === 'none') ||
        (activeFilter === 'cli' && hasCli);

      const matchCategory = activeCategory === 'all' || category === activeCategory;

      const show = matchFilter && matchCategory;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    emptyState.classList.toggle('hidden', visible > 0);
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.className = b.className.replace('bg-gray-900 text-white border-gray-900', 'bg-white text-gray-600 border-gray-200 hover:border-gray-400');
      });
      btn.className = btn.className.replace('bg-white text-gray-600 border-gray-200 hover:border-gray-400', 'bg-gray-900 text-white border-gray-900');
      activeFilter = btn.dataset.filter!;
      applyFilters();
    });
  });

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      catBtns.forEach(b => {
        b.className = b.className.replace('bg-gray-700 text-white border-gray-700', 'bg-white text-gray-500 border-gray-200 hover:border-gray-400');
      });
      btn.className = btn.className.replace('bg-white text-gray-500 border-gray-200 hover:border-gray-400', 'bg-gray-700 text-white border-gray-700');
      activeCategory = btn.dataset.category!;
      applyFilters();
    });
  });
</script>
