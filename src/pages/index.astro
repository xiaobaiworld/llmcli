---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';
import { getApps, getCoverageStats } from '../lib/apps';
import { getTools } from '../lib/tools';

const apps = getApps();
const tools = getTools();

// Total feature count across all apps
const totalFeatures = apps.reduce((sum, app) => sum + getCoverageStats(app).total, 0);
const totalSupported = apps.reduce((sum, app) => sum + getCoverageStats(app).supported, 0);
---

<BaseLayout title="llmcli — AI agent 应用操作手册">
  <!-- Hero -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-10">
      <div class="max-w-2xl">
        <h1 class="text-3xl font-bold text-gray-900 mb-3">
          AI agent 应用操作手册
        </h1>
        <p class="text-gray-600 text-base mb-6 leading-relaxed">
          以具体应用为中心，告诉你每个功能能不能通过 CLI / MCP 工具完成——
          支持的给命令示例，不支持的说明原因。
        </p>
        <div class="flex flex-wrap gap-6 text-sm text-gray-500">
          <span><strong class="text-gray-900 font-semibold">{apps.length}</strong> 个应用</span>
          <span><strong class="text-gray-900 font-semibold">{totalFeatures}</strong> 个功能点</span>
          <span><strong class="text-green-600 font-semibold">{totalSupported}</strong> 个可自动化</span>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-8">

    <!-- Pagefind search -->
    <div class="mb-8">
      <div id="search" class="max-w-xl"></div>
    </div>

    <!-- Section: Apps -->
    <section class="mb-12">
      <h2 class="text-lg font-bold text-gray-900 mb-4">应用覆盖矩阵</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {apps.map(app => <AppCard app={app} />)}
      </div>
    </section>

    <!-- Divider + link to old tool directory -->
    <div class="border-t border-gray-100 pt-8">
      <p class="text-sm text-gray-400">
        还在找通用 CLI 工具？
        <a href="/tools" class="text-blue-600 hover:underline">浏览通用 CLI 工具目录 →</a>
      </p>
    </div>
  </div>
</BaseLayout>

<!-- Pagefind search -->
<script>
  const link = document.createElement('link');
  link.rel = 'stylesheet';
  link.href = '/pagefind/pagefind-ui.css';
  document.head.appendChild(link);

  const script = document.createElement('script');
  script.src = '/pagefind/pagefind-ui.js';
  script.onload = () => {
    // @ts-ignore
    new PagefindUI({
      element: '#search',
      showSubResults: false,
      placeholder: '搜索应用或功能… 例如 "飞书 日历"、"MCP"',
      resetStyles: false,
    });
  };
  document.head.appendChild(script);
</script>

<style>
  #search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #2563eb;
    --pagefind-ui-text: #111827;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-tag: #f3f4f6;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: system-ui, sans-serif;
  }
</style>
