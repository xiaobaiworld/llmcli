{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmcli.local/schema/tools.schema.json",
  "title": "LLMCLI Tool Entry Schema v1",
  "type": "object",
  "required": ["version", "tools"],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tool"
      }
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "required": [
        "id",
        "name",
        "command",
        "category",
        "kind",
        "priority",
        "agent_ready_level",
        "agent_ready_score",
        "maintained",
        "install",
        "example"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "file-text",
            "http-api",
            "data-db",
            "dev-code",
            "ops",
            "llm-agent"
          ]
        },
        "kind": {
          "type": "string",
          "enum": ["traditional-cli", "ai-native-cli", "mcp-server", "wrapper-cli"]
        },
        "priority": {
          "type": "string",
          "enum": ["A", "B"]
        },
        "agent_ready_level": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "agent_ready_score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "maintained": {
          "type": "string",
          "enum": ["yes", "unknown", "no"]
        },
        "install": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["brew", "apt", "npm", "pip", "cargo", "go", "binary", "system", "docker"]
          },
          "uniqueItems": true
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "repo": {
          "type": "string",
          "format": "uri"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "example": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
