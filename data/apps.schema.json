{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "App",
  "description": "Schema for an application entry in the llmcli coverage matrix",
  "type": "object",
  "required": ["id", "name", "description", "category", "tools", "domains"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique slug identifier (kebab-case)",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "description": "Display name of the application"
    },
    "description": {
      "type": "string",
      "description": "One-line description of the application"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Official homepage URL"
    },
    "category": {
      "type": "string",
      "enum": ["enterprise-collab", "notes", "devtools", "project", "crm"],
      "description": "Application category"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "description": "CLI/MCP tools available for this application",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "install_cmd", "maintained"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["cli", "mcp", "mcp-remote", "api"]
          },
          "install_cmd": { "type": "string" },
          "repo": { "type": "string", "format": "uri" },
          "maintained": {
            "type": "string",
            "enum": ["official", "community", "unknown"]
          },
          "agent_skills": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "description": "Functional domains covered by the application",
      "items": {
        "type": "object",
        "required": ["id", "name", "features"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "features": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "name", "status"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "name": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["supported", "partial", "unsupported"]
                },
                "tool_id": { "type": "string" },
                "command": { "type": "string" },
                "input": { "type": "string" },
                "output": { "type": "string" },
                "notes": { "type": "string" },
                "gap_reason": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
